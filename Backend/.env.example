# ── FastAPI Configuration ────────────────────────────────────────────
APP_NAME=JobSpy Web Application
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ── Server Configuration ─────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
RELOAD=True

# ── Database Configuration ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://admin:admin@localhost:5432/jobspy_db
DATABASE_ECHO=True
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis Configuration ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── Cache TTL Configuration (in seconds) ──────────────────────────────
# Different cache types have different TTL values based on data freshness requirements
CACHE_TTL_JOBS=3600  # Jobs: 1 hour
CACHE_TTL_SEARCH_RESULTS=1800  # Search results: 30 minutes
CACHE_TTL_STATISTICS=3600  # Statistics: 1 hour
CACHE_TTL_USERS=86400  # Users: 24 hours
CACHE_TTL_SEARCH_HISTORY=3600  # Search history: 1 hour
CACHE_TTL_RECOMMENDATIONS=21600  # Recommendations: 6 hours
CACHE_TTL_TRENDING_SEARCHES=43200  # Trending searches: 12 hours

# ── JWT Configuration ───────────────────────────────────────────────
SECRET_KEY=jobspy-secret-key-2026-development
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Celery Configuration ────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Email Configuration ────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@jobspy.com
SENDER_NAME=JobSpy

# ── External APIs ──────────────────────────────────────────────────
LINKEDIN_API_KEY=your-linkedin-api-key
INDEED_API_KEY=your-indeed-api-key
WUZZUF_API_KEY=your-wuzzuf-api-key
BAYT_API_KEY=your-bayt-api-key

# ── CORS Configuration ────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ── Logging Configuration ────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── Pagination ──────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── Scraping Configuration ──────────────────────────────────────
SCRAPING_TIMEOUT=30
SCRAPING_RETRIES=3
SCRAPING_DELAY=1
