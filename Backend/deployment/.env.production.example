# ============================================================================
# JobSpy Production Environment Configuration
# ============================================================================
# Copy this file to .env.production and fill in the actual values
# NEVER commit the actual .env.production file to version control
# ============================================================================

# ============================================================================
# Application Settings
# ============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
APP_NAME=JobSpy
APP_VERSION=1.0.0

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://jobspy_user:your_secure_password@postgres:5432/jobspy_prod

# Database connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# ============================================================================
# Redis Configuration
# ============================================================================
# Redis connection string
REDIS_URL=redis://:your_redis_password@redis:6379/0

# Redis settings
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_KEEPALIVE=true
REDIS_SOCKET_KEEPALIVE_OPTIONS={}

# ============================================================================
# Security Configuration
# ============================================================================
# Secret key for JWT signing (minimum 32 characters)
SECRET_KEY=your_very_secure_secret_key_minimum_32_characters_long

# JWT algorithm
ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS settings
CORS_ORIGINS=["https://yourdomain.com", "https://www.yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# ============================================================================
# Email Configuration
# ============================================================================
# SMTP settings (using SendGrid as example)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=JobSpy
SMTP_USE_TLS=true

# Email settings
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_EXPIRY_HOURS=24
EMAIL_RESET_PASSWORD_EXPIRY_HOURS=1

# ============================================================================
# Celery Configuration
# ============================================================================
# Celery broker URL (Redis)
CELERY_BROKER_URL=redis://:your_redis_password@redis:6379/1

# Celery result backend
CELERY_RESULT_BACKEND=redis://:your_redis_password@redis:6379/2

# Celery settings
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3000

# ============================================================================
# Monitoring and Error Tracking
# ============================================================================
# Sentry configuration
SENTRY_DSN=your_sentry_dsn_url
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================================================
# AWS Configuration (for S3 exports)
# ============================================================================
# AWS credentials
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# S3 bucket for exports
AWS_S3_BUCKET=jobspy-exports
AWS_S3_EXPORT_PREFIX=exports/

# ============================================================================
# Frontend Configuration
# ============================================================================
# API URL for frontend
VITE_API_URL=https://api.yourdomain.com
VITE_APP_NAME=JobSpy
VITE_APP_DESCRIPTION=Find your perfect job

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_LEVEL_CONSOLE=info
LOG_LEVEL_FILE=debug

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_ADVANCED_SEARCH=true
FEATURE_EXPORT_CSV=true
FEATURE_EXPORT_EXCEL=true
FEATURE_EXPORT_JSON=true
FEATURE_ALERTS=true
FEATURE_SAVED_JOBS=true
FEATURE_USER_PROFILES=true

# ============================================================================
# Scraping Configuration
# ============================================================================
# Scraping timeout (seconds)
SCRAPING_TIMEOUT=30

# Maximum results per search
SCRAPING_MAX_RESULTS=1000

# Retry configuration
SCRAPING_MAX_RETRIES=3
SCRAPING_RETRY_DELAY=5

# ============================================================================
# Cache Configuration
# ============================================================================
# Cache TTL (Time To Live) in seconds
CACHE_TTL_SEARCH_RESULTS=3600
CACHE_TTL_JOB_DETAILS=604800
CACHE_TTL_USER_PROFILE=86400
CACHE_TTL_STATISTICS=3600

# ============================================================================
# Database Backup Configuration
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=jobspy-backups

# ============================================================================
# Health Check Configuration
# ============================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=60

# ============================================================================
# API Documentation
# ============================================================================
API_DOCS_ENABLED=true
API_DOCS_URL=/docs
API_REDOC_URL=/redoc

# ============================================================================
# Security Headers
# ============================================================================
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true

# ============================================================================
# HTTPS/SSL Configuration
# ============================================================================
SSL_ENABLED=true
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
SSL_PROTOCOLS=TLSv1.2 TLSv1.3
SSL_CIPHERS=HIGH:!aNULL:!MD5

# ============================================================================
# Docker Registry Configuration
# ============================================================================
DOCKER_REGISTRY=docker.io
BACKEND_VERSION=latest
FRONTEND_VERSION=latest

# ============================================================================
# Proxy Configuration (Optional)
# ============================================================================
# HTTP_PROXY=http://proxy.yourdomain.com:8080
# HTTPS_PROXY=http://proxy.yourdomain.com:8080
# NO_PROXY=localhost,127.0.0.1,postgres,redis

# ============================================================================
# Additional Configuration
# ============================================================================
# Maximum file upload size (bytes)
MAX_UPLOAD_SIZE=10485760

# Session timeout (seconds)
SESSION_TIMEOUT=1800

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true
